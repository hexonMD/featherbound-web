# Prodigi print-on-demand (server-side only — never expose to the client)
PRODIGI_API_KEY=
# Stripe (payment) — server-side only. Live key sells real prints.
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (whsec_...) for /api/stripe/webhook — from the Stripe
# dashboard endpoint, or auto-created via the API. Required for fulfilment to fire.
STRIPE_WEBHOOK_SECRET=
